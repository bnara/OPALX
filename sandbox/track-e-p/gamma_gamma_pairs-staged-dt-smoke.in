OPTION, PSDUMPFREQ = -1;
OPTION, STATDUMPFREQ = 5000;
OPTION, BOUNDPDESTROY = 10;
OPTION, VERSION = 10900;
OPTION, SEED = 42;

TITLE, STRING = "Gamma-gamma BeamBeam staged-DT smoke test";

// Primary 245 MeV electron beam.
REAL primary_kinetic_energy = 0.245;     // GeV
REAL primary_gamma = (primary_kinetic_energy + EMASS) / EMASS;
REAL primary_beta = sqrt(1.0 - 1.0 / (primary_gamma^2));
REAL primary_p0 = primary_gamma * primary_beta * EMASS;  // GeV/c
REAL primary_beta_gamma = primary_p0 / EMASS;

REAL primary_geometric_emittance = 5.2e-9;  // m rad
REAL primary_beta_function = 0.727e-3;      // m
REAL primary_sigma_xy = sqrt(primary_geometric_emittance * primary_beta_function);
REAL primary_sigma_xyp = sqrt(primary_geometric_emittance / primary_beta_function);
REAL primary_sigma_pxy = primary_beta_gamma * primary_sigma_xyp;
REAL primary_sigma_z = 0.6e-3;              // m

REAL primary_electrons_per_bunch = 1.25e10;
REAL primary_macroparticles = 32;
REAL elementary_charge = 1.602176634e-19;
REAL primary_bunch_charge = primary_electrons_per_bunch * elementary_charge;

// Small pair sample for a fast staged-DT parser/tracker smoke test.
REAL n_pairs_per_species = 4;
REAL pair_bunch_charge = n_pairs_per_species * elementary_charge;

// Interaction point and large BeamBeam tracking cylinder.
REAL drift_length = 0.01;
REAL bb_length = 0.32;
REAL bb_ip_s = drift_length + 0.5*bb_length;

// Tiny staged-DT smoke test: start the fine segment near the primary IP time
// and inject the small witness sample there.  This validates the OPALX
// MAXSTEPS/DT vector mechanics without running the full production window.
REAL light_speed = 299792458.0;
REAL primary_ip_time = bb_ip_s / light_speed;
REAL tinj = primary_ip_time;
REAL primary_retire_time = 1000e-12;
REAL coarse_steps = 567;
REAL fine_steps = 1000;
REAL coarse_dt = 1.0e-12;
REAL fine_dt = 1.0e-15;

// Fieldsolver configuration.
REAL N = 4;

DR_UP: DRIFT,  L = drift_length, ELEMEDGE = 0.0;
IP1: BEAMBEAM, L = bb_length,    ELEMEDGE = drift_length, VISUALIZE = FALSE, COPY_TIME = 50e-12, WITNESS_CONTAINERS = "1,2", RETIRE_TIME = primary_retire_time, APERTURE="CIRCLE(0.30)";
DR_DN: DRIFT,  L = drift_length, ELEMEDGE = drift_length + bb_length;

pairLine: LINE = (DR_UP, IP1, DR_DN);

FS1: FIELDSOLVER, TYPE = OPEN,
    NX = N, NY = N, NZ = N,
    PARFFTX = FALSE, PARFFTY = FALSE, PARFFTZ = TRUE,
    BCFFTX = OPEN, BCFFTY = OPEN, BCFFTZ = OPEN;

DistPrimaryElectrons: DISTRIBUTION, TYPE = GAUSS,
    SIGMAX = primary_sigma_xy, SIGMAY = primary_sigma_xy, SIGMAZ = primary_sigma_z,
    SIGMAPX = primary_sigma_pxy, SIGMAPY = primary_sigma_pxy, SIGMAPZ = 1.0e-12,
    NPARTDIST = primary_macroparticles;

DistElectrons: DISTRIBUTION, TYPE = FROMFILE,
    FNAME = "gamma_gamma_electrons.fromfile",
    NPARTDIST = n_pairs_per_species;

DistPositrons: DISTRIBUTION, TYPE = FROMFILE,
    FNAME = "gamma_gamma_positrons.fromfile",
    NPARTDIST = n_pairs_per_species;

SourcePrimaryElectrons: EMISSIONSOURCE, DISTRIBUTION = DistPrimaryElectrons;
SourceElectrons: EMISSIONSOURCE, DISTRIBUTION = DistElectrons, T0=tinj, R0Z=bb_ip_s;
SourcePositrons: EMISSIONSOURCE, DISTRIBUTION = DistPositrons, T0=tinj, R0Z=bb_ip_s;

PrimaryElectronSources: EMISSIONSOURCELIST = (SourcePrimaryElectrons);
ElectronSources: EMISSIONSOURCELIST = (SourceElectrons);
PositronSources: EMISSIONSOURCELIST = (SourcePositrons);

PrimaryElectrons: BEAM,
    PARTICLE = ELECTRON,
    PC = primary_p0,
    NALLOC = primary_macroparticles,
    BCHARGE = primary_bunch_charge,
    SOURCES = PrimaryElectronSources;

GammaGammaElectrons: BEAM,
    PARTICLE = ELECTRON,
    NALLOC = n_pairs_per_species,
    BCHARGE = pair_bunch_charge,
    SOURCES = ElectronSources;

GammaGammaPositrons: BEAM,
    PARTICLE = POSITRON,
    NALLOC = n_pairs_per_species,
    BCHARGE = pair_bunch_charge,
    SOURCES = PositronSources;

TRACK, LINE = pairLine,
    BEAMS = {PrimaryElectrons, GammaGammaElectrons, GammaGammaPositrons},
    MAXSTEPS = {coarse_steps, fine_steps},
    ZSTOP = 2*drift_length + bb_length,
    DT = {coarse_dt, fine_dt};
 RUN, METHOD = "PARALLEL", FIELDSOLVER = FS1;
ENDTRACK;

QUIT;
