OPTION, PSDUMPFREQ = 50000;
OPTION, STATDUMPFREQ = 1;
OPTION, BOUNDPDESTROY = 10;
OPTION, VERSION = 10900;
OPTION, ASCIIDUMP = TRUE;

Title, string = "test-rbend-1 single analytic RBEND placement regression";

// Single-RBEND regression seed with a 30 cm upstream drift before the bend.
//
// Analytic configuration:
//   upstream drift = 0.3 m
//   L       = 1.0 m rectangular body length
//   ANGLE   = +45 deg
//   E1      = 0 deg
//   E2      = ANGLE - E1 = +45 deg
//   HGAP    = 0.02 m
//   FINT    = 0.5
//
// The drift starts at the input start and the RBEND entrance edge is centered
// at the drift exit:
//   x_entry_edge_lab = 0.0 m
//   z_entry_edge_lab = 0.3 m
// and the single-particle distribution starts exactly at (0, 0, 0).
//
// Old-OPAL-compatible rectangular chart with the entrance tangent along +Z:
//   L_ref   = L * (ANGLE / 2) / sin(ANGLE / 2)
//   r_exit  = r_entry + (-L tan(ANGLE / 2), 0, L)
//   t_exit  = (-sin(ANGLE), 0, cos(ANGLE))
//
// OPALX stores the RBEND body pose at the straight rectangular body frame.
// The local entry edge relative to the body is
//   r_entry_from_body = (-0.5 L tan(ANGLE / 4), 0, 0.5 L)
// and the body is rotated by -ANGLE/2.  BODY_X/BODY_Z below are therefore
// derived by rotating that local entry vector into the lab and subtracting it
// from the requested entrance-edge location.

REAL DRIFT_LENGTH = 0.3;
REAL BEND_LENGTH  = 1.0;
REAL BEND_ANGLE   = PI / 4;
REAL BEND_E1      = 0.0;
REAL BEND_E2      = BEND_ANGLE - BEND_E1;
REAL BEND_HGAP    = 0.02;
REAL BEND_FINT    = 0.5;

REAL ENTRY_X      = 0.0;
REAL ENTRY_Z      = DRIFT_LENGTH;
REAL BODY_THETA   = -BEND_ANGLE / 2;
REAL ENTRY_LOCAL_X = -0.5 * BEND_LENGTH * tan(BEND_ANGLE / 4);
REAL ENTRY_LOCAL_Z = 0.5 * BEND_LENGTH;
REAL ENTRY_FROM_BODY_X =
    cos(BODY_THETA) * ENTRY_LOCAL_X + sin(BODY_THETA) * ENTRY_LOCAL_Z;
REAL ENTRY_FROM_BODY_Z =
    -sin(BODY_THETA) * ENTRY_LOCAL_X + cos(BODY_THETA) * ENTRY_LOCAL_Z;
REAL BODY_X       = ENTRY_X - ENTRY_FROM_BODY_X;
REAL BODY_Z       = ENTRY_Z - ENTRY_FROM_BODY_Z;
REAL EXIT_X       = ENTRY_X - BEND_LENGTH * tan(BEND_ANGLE / 2);
REAL EXIT_Z       = ENTRY_Z + BEND_LENGTH;
REAL EXIT_THETA   = -BEND_ANGLE;

DPRE: DRIFT,
    L = DRIFT_LENGTH,
    X = 0.0,
    Y = 0.0,
    Z = DRIFT_LENGTH / 2,
    THETA = 0.0,
    PHI = 0.0,
    PSI = 0.0;

B1: RBEND,
    L = BEND_LENGTH,
    ANGLE = BEND_ANGLE,
    E1 = BEND_E1,
    E2 = BEND_E2,
    HGAP = BEND_HGAP,
    FINT = BEND_FINT,
    X = BODY_X,
    Y = 0.0,
    Z = BODY_Z,
    THETA = BODY_THETA,
    PHI = 0.0,
    PSI = 0.0;

MEXIT: MONITOR,
    L = 0.0,
    X = EXIT_X,
    Y = 0.0,
    Z = EXIT_Z,
    THETA = EXIT_THETA,
    PHI = 0.0,
    PSI = 0.0,
    TYPE = TEMPORAL,
    OUTFN = "test-rbend-1_exit_monitor";

Line1: LINE = (DPRE, B1, MEXIT);

Dist0: DISTRIBUTION,
    TYPE = FROMFILE,
    FNAME = "test-rbend-1_distribution.txt",
    NPARTDIST = 1;

ES0: EMISSIONSOURCE, DISTRIBUTION = Dist0;
Sources0: EMISSIONSOURCELIST = (ES0);

FS0: FIELDSOLVER,
    TYPE = NONE,
    NX = 16,
    NY = 16,
    NZ = 16,
    PARFFTX = false,
    PARFFTY = false,
    PARFFTZ = true,
    BCFFTX = open,
    BCFFTY = open,
    BCFFTZ = open,
    BBOXINCR = 1,
    GREENSF = INTEGRATED;

BEAM0: BEAM,
    PARTICLE = ELECTRON,
    NALLOC = 1,
    BCHARGE = 1.6021766339999998e-19,
    SOURCES = Sources0,
    CHARGE = -1;

TRACK,
    LINE = Line1,
    BEAM = BEAM0,
    MAXSTEPS = 20000,
    DT = 1.0e-12,
    ZSTOP = 1.6;

RUN,
    METHOD = "PARALLEL",
    FIELDSOLVER = FS0;

ENDTRACK;

QUIT;
